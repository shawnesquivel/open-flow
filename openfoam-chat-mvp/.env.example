ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Path to the tutorial case that acts as the template.
OPENFOAM_TEMPLATE_CASE=/Users/shawnesquivel/Downloads/pitzDaily

# Ephemeral workspace copied from the template before each run.
OPENFOAM_WORK_ROOT=/tmp/openfoam-chat

# Commands are executed after sourcing this file.
OPENFOAM_BASHRC=/opt/openfoam12/etc/bashrc

# Public-ish folder for images/csvs served back to the UI.
OPENFOAM_ARTIFACT_DIR=/tmp/openfoam-chat/public-artifacts

# Local mocked demo asset folder used by /demo.
OPENFOAM_DEMO_ASSET_DIR=/Users/shawnesquivel/Downloads/pitzDaily-viz
